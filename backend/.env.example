# ══════════════════════════════════════════════════════════════
# MediConnect Backend — .env.example
# Copy to .env and fill in real values.
# NEVER commit .env to Git — only commit .env.example
# ══════════════════════════════════════════════════════════════

# Django
SECRET_KEY=your-super-secret-django-key-here-minimum-50-chars
DEBUG=False
ALLOWED_HOSTS=mediconnect.salman-aak.com,api.mediconnect.salman-aak.com
DJANGO_SETTINGS_MODULE=mediconnect.settings.production

# PostgreSQL
DATABASE_HOST=postgres-service
DATABASE_PORT=5432
DATABASE_NAME=mediconnect
DATABASE_USER=mediconnect_user
DATABASE_PASSWORD=your-strong-database-password-here

# MongoDB
MONGODB_URI=mongodb://mediconnect_user:password@mongodb-service:27017/mediconnect?authSource=admin

# Redis
REDIS_URL=redis://redis-service:6379/0
CELERY_BROKER_URL=redis://redis-service:6379/1

# Twilio (get from console.twilio.com)
TWILIO_ACCOUNT_SID=MY_TWILIO_ACCOUNT_SID
TWILIO_AUTH_TOKEN=MY_TWILIO_AUTH_TOKEN
TWILIO_PHONE_NUMBER=MY_TWILIO_PHONE_NUMBER

# SendGrid (get from app.sendgrid.com → Settings → API Keys)
SENDGRID_API_KEY=YOUR_SENDGRID_API_KEY

# OpenAI (get from platform.openai.com → API Keys)
OPENAI_API_KEY=YOUR_OPENAI_API_KEY

# AWS
AWS_ACCESS_KEY_ID=YOUR_AWS_ACCESS_KEY_ID
AWS_SECRET_ACCESS_KEY=YOUR_AWS_SECRET_ACCESS_KEY
AWS_STORAGE_BUCKET_NAME=mediconnect-storage-aak
AWS_S3_REGION_NAME=us-east-1

# CORS
CORS_ALLOWED_ORIGINS=https://mediconnect.salman-aak.com


# =====================================================
# MediConnect - Root Environment Configuration
# =====================================================
# Copy this file to .env before running locally.
# Never commit the real .env file.
# =====================================================

# -----------------------------------------------------
# Project
# -----------------------------------------------------
PROJECT_NAME=mediconnect
ENVIRONMENT=development

# -----------------------------------------------------
# AWS
# -----------------------------------------------------
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=AKIAXXXXXXXXXXXXXXXXXXXX
AWS_SECRET_ACCESS_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
AWS_ACCOUNT_ID=123456789012

# -----------------------------------------------------
# Terraform
# -----------------------------------------------------
TF_VAR_aws_region=us-east-1
TF_VAR_domain_name=mediconnect.salman-aak.com

# -----------------------------------------------------
# Domain
# -----------------------------------------------------
DOMAIN_NAME=mediconnect.salman-aak.com
API_DOMAIN=api.mediconnect.salman-aak.com
WS_DOMAIN=ws.mediconnect.salman-aak.com

# -----------------------------------------------------
# Kubernetes
# -----------------------------------------------------
KUBE_NAMESPACE=mediconnect

# -----------------------------------------------------
# Database
# -----------------------------------------------------
POSTGRES_DB=mediconnect
POSTGRES_USER=mediconnect_user
POSTGRES_PASSWORD=your_postgres_password

# -----------------------------------------------------
# MongoDB
# -----------------------------------------------------
MONGO_INITDB_ROOT_USERNAME=mediconnect_user
MONGO_INITDB_ROOT_PASSWORD=your_mongodb_password

# -----------------------------------------------------
# Redis
# -----------------------------------------------------
REDIS_PASSWORD=your_redis_password

# -----------------------------------------------------
# External APIs
# -----------------------------------------------------
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890

SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# -----------------------------------------------------
# Storage
# -----------------------------------------------------
S3_BUCKET_NAME=mediconnect-storage-aak

# -----------------------------------------------------
# SSL
# -----------------------------------------------------
EMAIL_FOR_LETSENCRYPT=your-email@example.com
